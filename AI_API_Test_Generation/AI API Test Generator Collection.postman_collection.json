    {
      "name": "3 - Get User by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let jsonData = pm.response.json();",
              "",
              "// STATUS CODE",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// RESPONSE TIME",
              "pm.test(\"Response time < 2 seconds\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "// REQUIRED FIELD VALIDATION",
              "pm.test(\"User response contains required fields\", function () {",
              "    pm.expect(jsonData).to.have.property(\"id\");",
              "    pm.expect(jsonData).to.have.property(\"email\");",
              "    pm.expect(jsonData).to.have.property(\"name\");",
              "});",
              "",
              "// POSITIVE TEST",
              "pm.test(\"User ID matches requested ID\", function () {",
              "    pm.expect(jsonData.id.toString()).to.eql(pm.variables.get(\"userId\"));",
              "});",
              "",
              "// NEGATIVE TEST",
              "pm.test(\"Invalid userId should return error\", function () {",
              "    if(pm.variables.get(\"userId\") === \"999999\"){",
              "        pm.expect(pm.response.code).to.not.equal(200);",
              "    }",
              "});",
              "",
              "// EDGE CASE",
              "pm.test(\"Email format validation\", function () {",
              "    pm.expect(jsonData.email).to.match(/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
