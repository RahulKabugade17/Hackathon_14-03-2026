  "item": [
    {
      "name": "1 - Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse response",
              "let jsonData = pm.response.json();",
              "",
              "// STATUS CODE VALIDATION",
              "pm.test(\"Status code should be 200 or 201\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200,201]);",
              "});",
              "",
              "// RESPONSE TIME VALIDATION",
              "pm.test(\"Response time should be less than 2000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "// RESPONSE SCHEMA VALIDATION",
              "pm.test(\"Response should contain access_token and refresh_token\", function () {",
              "    pm.expect(jsonData).to.have.property(\"access_token\");",
              "    pm.expect(jsonData).to.have.property(\"refresh_token\");",
              "});",
              "",
              "// POSITIVE TEST",
              "pm.test(\"Access token should not be empty\", function () {",
              "    pm.expect(jsonData.access_token).to.not.be.empty;",
              "});",
              "",
              "// NEGATIVE TEST",
              "pm.test(\"Invalid credentials should not return 200\", function () {",
              "    if(pm.request.body.raw.includes(\"wrongpassword\")){",
              "        pm.expect(pm.response.code).to.not.equal(200);",
              "    }",
              "});",
              "",
              "// EDGE CASE TEST",
              "pm.test(\"Token length validation\", function () {",
              "    pm.expect(jsonData.access_token.length).to.be.above(10);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n\"email\":\"john@mail.com\",\n\"password\":\"changeme\"\n}"
        },
        "url": {
          "raw": "https://api.escuelajs.co/api/v1/auth/login",
          "protocol": "https",
          "host": [
            "api",
            "escuelajs",
            "co"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      },
      "response": []
