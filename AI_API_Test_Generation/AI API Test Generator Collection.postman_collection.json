              "",
              "// MISSING PARAMETER TEST",
              "pm.test(\"Missing required field should return error\", function () {",
              "    let body = JSON.parse(pm.request.body.raw);",
              "    if(!body.email){",
              "        pm.expect(pm.response.code).to.not.equal(200);",
              "    }",
              "});",
              "",
              "// EDGE CASE",
              "pm.test(\"Name length validation\", function () {",
              "    pm.expect(jsonData.name.length).to.be.above(2);",
