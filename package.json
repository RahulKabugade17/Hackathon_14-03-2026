{
  "name": "appium-mobile-starter",
  "version": "1.0.0",
  "scripts": {
    "android": "npx wdio ./src/config/wdio.android.config.js",
    "ios": "npx wdio ./src/config/wdio.ios.config.js",
    "report": "npm run allure:generate && npm run allure:open",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@wdio/allure-reporter": "^9.19.1",
    "@wdio/appium-service": "^9.19.2",
    "@wdio/cli": "^9.19.1",
    "@wdio/cucumber-framework": "^9.19.1",
    "@wdio/local-runner": "^9.19.1",
    "@wdio/spec-reporter": "^9.19.1",
    "allure-commandline": "^2.34.0",
    "appium": "^2.5.1",
    "appium-uiautomator2-driver": "^2.34.0",
    "appium-xcuitest-driver": "^9.10.5",
    "eslint": "^10.0.1",
    "globals": "^17.3.0",
    "playwright": "^1.58.2",
    "webdriverio": "^9.19.1"
  },
  "dependencies": {
    "appium-uiautomator2-driver": "^4.2.1",
    "appium-xcuitest-driver": "^9.2.1",
    "axios": "^1.13.2"
  }
}
