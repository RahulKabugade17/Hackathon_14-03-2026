{
  "name": "appium-mobile-starter",
  "version": "1.0.0",
  "scripts": {
    "android": "npx wdio src/config/wdio.android.config.js",
    "ios": "npx wdio ./src/config/wdio.ios.conf.js",
    "report": "npm run allure:generate && npm run allure:open",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "type": "module",
  "devDependencies": {
    "@babel/cli": "^7.27.0",
    "@babel/core": "^7.26.10",
    "@babel/preset-env": "^7.26.9",
    "@babel/register": "^7.25.9",
    "@wdio/allure-reporter": "^9.12.6",
    "@wdio/appium-service": "^9.12.7",
    "@wdio/cli": "^9.12.7",
    "@wdio/cucumber-framework": "^9.12.2",
    "@wdio/local-runner": "^9.12.7",
    "@wdio/spec-reporter": "^9.12.6",
    "allure-commandline": "^2.34.0",
    "webdriverio": "^9.12.7"
  },
  "dependencies": {
    "appium-uiautomator2-driver": "^4.2.1",
    "appium-xcuitest-driver": "^9.2.1"
  }
}
