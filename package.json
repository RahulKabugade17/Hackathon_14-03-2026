{
  "name": "appium-mobile-starter",
  "version": "1.0.0",
  "scripts": {
    "android": "npx wdio run ./src/config/wdio.android.config.js",
    "ios": "npx wdio run ./src/config/wdio.ios.config.js",
    "report": "npm run allure:generate && npm run allure:open",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "serenity": "failsafe serenity:clean wdio serenity:report",
    "serenity:clean": "rimraf target",
    "wdio": "wdio run ./wdio.conf.js",
    "serenity:report": "serenity-bdd run"
  },
  "type": "module",
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@eslint/js": "^10.0.1",
    "@serenity-js/assertions": "^3.41.2",
    "@serenity-js/console-reporter": "^3.41.2",
    "@serenity-js/core": "^3.41.2",
    "@serenity-js/cucumber": "^3.41.2",
    "@serenity-js/rest": "^3.41.2",
    "@serenity-js/serenity-bdd": "^3.41.2",
    "@serenity-js/web": "^3.41.2",
    "@serenity-js/webdriverio": "^3.41.2",
    "@wdio/allure-reporter": "^9.19.1",
    "@wdio/appium-service": "^9.25.0",
    "@wdio/cli": "^9.25.0",
    "@wdio/cucumber-framework": "^9.19.1",
    "@wdio/local-runner": "^9.25.0",
    "@wdio/spec-reporter": "^9.25.0",
    "allure-commandline": "^2.34.0",
    "appium": "^2.5.1",
    "appium-uiautomator2-driver": "^2.45.1",
    "appium-xcuitest-driver": "^9.10.5",
    "eslint": "^10.0.1",
    "globals": "^17.3.0",
    "npm-failsafe": "^1.4.0",
    "playwright": "^1.58.2",
    "rimraf": "^6.1.3",
    "webdriverio": "^9.19.1"
  },
  "dependencies": {
    "appium-uiautomator2-driver": "^4.2.1",
    "appium-xcuitest-driver": "^9.2.1",
    "axios": "^1.13.2"
  }
}